generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  password      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  visits        Visit[]
  familyMembers FamilyMember[]
}

model FamilyMember {
  id           String   @id @default(uuid())
  name         String
  relationship String
  dateOfBirth  DateTime?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  visits       Visit[]

  @@index([userId])
}

model Visit {
  id             String             @id @default(uuid())
  visitDate      DateTime
  doctorName     String
  hospital       String
  reason         String
  notes          String             @default("")
  tags           String[]           @default([])
  followUpDate   DateTime?
  followUpNote   String             @default("")
  userId         String
  memberId       String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  member         FamilyMember?      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  prescriptions  PrescriptionFile[]
  reports        ReportFile[]

  @@index([userId])
  @@index([visitDate])
  @@index([memberId])
}

model PrescriptionFile {
  id           String   @id @default(uuid())
  originalName String
  storageKey   String
  fileType     String
  fileSize     Int
  uploadedAt   DateTime @default(now())
  visitId      String
  visit        Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}

model ReportFile {
  id           String   @id @default(uuid())
  originalName String
  storageKey   String
  fileType     String
  fileSize     Int
  uploadedAt   DateTime @default(now())
  visitId      String
  visit        Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}
