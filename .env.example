# ── Database (Neon PostgreSQL — free tier) ────────────────────
# Sign up: https://neon.tech → Create project → Copy connection string
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/medtrack?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────
# iron-session encryption key — MUST be at least 32 characters
# Generate: openssl rand -base64 32
AUTH_SECRET="CHANGE-ME-generate-with-openssl-rand-base64-32"

# ── File Storage (Azure Blob Storage) ─────────────────────────
# Azure Portal → Storage Accounts → Create → Get name + key from Access Keys
AZURE_STORAGE_ACCOUNT_NAME="your-storage-account"
AZURE_STORAGE_ACCOUNT_KEY="your-access-key"
AZURE_STORAGE_CONTAINER="medtrack-uploads"
